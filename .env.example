# ─────────────────────────────────────────────────────────────────────────────
# Vietnam Legal RAG — environment variables
# Copy this file to `.env` and fill in your own values:
#     cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# LLM provider API keys (set at least one; depending on which provider you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── LLM ──────────────────────────────────────────────────────────────────────
# Model name used by the generation step. Examples:
#   openai:     gpt-4o-mini, gpt-4o, gpt-4-turbo
#   anthropic:  claude-haiku-4-5, claude-sonnet-4-6
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ── Embeddings ───────────────────────────────────────────────────────────────
# Vietnamese-friendly sentence-transformer model.
# Defaults to a popular Vietnamese SBERT (~250 MB, runs on CPU).
EMBEDDING_MODEL=keepitreal/vietnamese-sbert
EMBEDDING_DEVICE=cpu                # "cpu" | "cuda" | "mps"
EMBEDDING_BATCH_SIZE=32

# ── Vector store ─────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=data/index
CHROMA_COLLECTION_NAME=vietnam_legal

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ────────────────────────────────────────────────────────────────
RETRIEVAL_K=5
RETRIEVAL_SCORE_THRESHOLD=0.0       # cosine distance threshold; 0.0 disables

# ── Scraping ─────────────────────────────────────────────────────────────────
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; VietnamLegalRAG/0.1)
SCRAPER_REQUEST_TIMEOUT=30
SCRAPER_RATE_LIMIT_SECONDS=1.0
SCRAPER_BASE_URL=https://thuvienphapluat.vn
